{
  "name": "@xingm/vmap-cesium-toolbar",
  "version": "0.0.1-alpha.7",
  "description": "A powerful Cesium map toolbar plugin with drawing, measurement, and interaction features",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./style": "./dist/style.css"
  },
  "scripts": {
    "dev": "vite --force",
    "build": "vite build && vite build --mode lib",
    "build:lib": "vite build --mode lib",
    "build:plugin": "node scripts/build-plugin.js",
    "generate:file-list": "node scripts/generate-file-list.js",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "dependencies": {
    "cesium": "^1.134.1",
    "vue": "^3.5.18"
  },
  "devDependencies": {
    "@types/cesium": "^1.70.4",
    "@vitejs/plugin-vue": "^6.0.1",
    "rollup-plugin-dts": "^6.1.0",
    "vite": "^7.1.2",
    "vite-plugin-cesium": "^1.2.23",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-static-copy": "^3.1.2",
    "vue-tsc": "^3.0.5"
  },
  "keywords": [
    "cesium",
    "map",
    "toolbar",
    "drawing",
    "measurement",
    "vue3",
    "typescript"
  ],
  "author": "pengxueyou",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/benxueyou/vmap-cesium-toolbar.git"
  },
  "bugs": {
    "url": "https://github.com/benxueyou/vmap-cesium-toolbar/issues"
  },
  "homepage": "https://github.com/benxueyou/vmap-cesium-toolbar#readme"
}
